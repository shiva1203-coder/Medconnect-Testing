FLASK_ENV=production
SECRET_KEY=replace-with-strong-secret

# Example sqlite for local demo:
# DATABASE_URL=sqlite:///medconnect.db
# Example mysql:
# DATABASE_URL=mysql+pymysql://user:password@db:3306/medconnect_db
DATABASE_URL=sqlite:///medconnect.db

OTP_EXPIRY_SECONDS=300
OTP_MAX_RETRIES=3
IVR_RATE_LIMIT=10/minute
ADMIN_API_KEY=replace-admin-key
PORT=5000
